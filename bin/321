#!/usr/bin/env perl

# 321 — CLI for managing services
# Delegates to Mojolicious commands in bin/321.pl
#
# Usage: 321 install zorda.web   (first-time setup)
#        321 go zorda.web        (deploy)
#        321 start/stop/restart zorda.web
#        321 status [service]
#        321 list
#        321 generate

use v5.18;
use strict;
use warnings;
use File::Basename qw(dirname);

my $app = dirname(__FILE__) . '/321.pl';

# Pass all args through to the Mojolicious app
exec('perl', $app, @ARGV);
