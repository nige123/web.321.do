# Minimum versions pinned to current releases. Install into a project-local
# local/lib/perl5 (cpanm -L local) so the app and its `321` test gate use these
# exact versions, never a drifted ambient perlbrew site_perl.
requires 'Mojolicious', '>= 9.46';
requires 'Mojo::Pg',    '>= 5.0';   # Minion::Backend::Pg needs Mojo::Pg 5 - older site_perl 4.x won't load
requires 'Minion',      '>= 12.0';
requires 'Nanoid',      '>= 0.04';  # opaque session tokens
requires 'Crypt::URandom', '>= 0.55';  # OS CSPRNG for passcodes - rand() must never mint an OTP
# Digest::SHA is core (passcode + token hashing).

# Feature skills add their own deps to this file:
#   321-passkeys -> Authen::WebAuthn, CBOR::XS, CryptX
#   321-stripe   -> (none new; uses core Digest::SHA + Mojo::UserAgent)

on 'test' => sub {
    requires 'Test::Most', '>= 0.42';
};
